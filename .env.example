# --- Telegram Configuration ---
# Token for your Telegram Bot from @BotFather
TELEGRAM_BOT_TOKEN=

# Channel identifier (e.g., @my_channel or -1001234567890)
# Make sure the bot is added as an administrator with post/edit permissions
TELEGRAM_CHANNEL_ID=

# Message ID to edit in the channel.
# If left blank, the bot will post a new message when started, output the ID, and automatically update this file.
TELEGRAM_MESSAGE_ID=


# --- Spotify Configuration ---
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=

SPOTIFY_CLIENT_SECRET=

# Must match one of the Redirect URIs in your Spotify App settings exactly
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Will be automatically filled by auth.py
SPOTIFY_REFRESH_TOKEN=

# --- Bot Settings ---
# How often to check Spotify and update Telegram (in seconds, minimum 5 seconds recommended due to rate limits)
UPDATE_INTERVAL=5

# --- Bot Language ---
# Language setting for Telegram status messages (ru for Russian, en for English)
LANGUAGE=ru
